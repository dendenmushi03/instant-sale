<!doctype html>
<html lang="<%= lng || 'ja' %>">
<head>
  <%- include('../partials/head', { title: t('image_license.title') + ' | ' + t('brand'), canonical, robots }) %>
</head>
<body class="layout legal licensePage">
  <%- include('../partials/header') %>

  <main class="container">
    <article class="card licenseCard">
      <header class="licenseHeader">
        <h1><%= t('image_license.h1') %></h1>
        <% const _d = new Date(); const _iso = _d.toISOString().slice(0,10); %>
        <p class="muted licenseUpdated"><%= t('image_license.page.last_updated_prefix', { date: _iso }) %></p>
      </header>

      <section class="licenseSection">
        <h2><%= t('image_license.page.common_title') %></h2>
        <%- t('image_license.page.common_rules_html') %>
      </section>

      <section class="licenseSection">
        <h2><%= t('image_license.page.presets_title') %></h2>

        <h3><%= t('image_license.page.personal_title') %></h3>
        <%- t('image_license.page.personal_desc_html') %>

        <h3><%= t('image_license.page.standard_title') %></h3>
        <%- t('image_license.page.standard_desc_html') %>

        <h3><%= t('image_license.page.lite_title') %></h3>
        <%- t('image_license.page.lite_desc_html') %>

        <h3><%= t('image_license.page.exclusive_title') %></h3>
        <%- t('image_license.page.exclusive_desc_html') %>
      </section>

      <p class="licenseActions">
        <a class="btn btn--primary" href="/creator"><%= t('upload.h1') %></a>
      </p>

      <p class="muted legal-note"><%- t('image_license.note.payout_expiration_html') %></p>
    </article>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
