<!doctype html>
<html lang="<%= lng || 'ja' %>">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <title><%= (typeof og !== 'undefined' && og.title) ? og.title : t('home.title_full') %></title>
  <meta name="description" content="<%= (typeof og !== 'undefined' && og.desc) ? og.desc : t('home.hero.lead') %>" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content="<%= (og && og.title) || '' %>" />
  <meta property="og:description" content="<%= (og && og.desc) || '' %>" />
  <meta property="og:url" content="<%= (og && og.url) || (baseUrl || '') %>" />
  <meta property="og:image" content="<%= (og && og.image) || (baseUrl ? (baseUrl + '/public/og/instantsale_ogp.jpg') : '') %>" />

  <!-- X(Twitter) -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="<%= (og && og.title) || '' %>" />
  <meta name="twitter:description" content="<%= (og && og.desc) || '' %>" />
  <meta name="twitter:image" content="<%= (og && og.image) || (baseUrl ? (baseUrl + '/public/og/instantsale_ogp.jpg') : '') %>" />

  <link rel="stylesheet" href="/public/style.css?v=<%= assetVer %>" />
  <link rel="icon" href="/public/logo.png?v=<%= assetVer %>" />

  <!-- SEO basic -->
  <link rel="canonical" href="<%= canonical %>" />
  <meta name="robots" content="<%= robots %>" />

</head>

<body class="layout">

<%- include('partials/header') %>

<main class="container">
  <!-- BEFORE: hero + many duplicated trust/value blocks -->
  <!-- AFTER: compact hero -> 3 features -> preview -> howto -> faq -> final CTA -->

  <section class="homeHero heroHome">
    <div class="homeHero__grid homeHero__grid--single">
      <div class="homeHero__copy">
        <p class="homeHero__kicker"><%= lng === 'en' ? 'AI creators' : 'AIクリエイター向け' %></p>
        <h1 class="homeHero__title heroHome__title">
          <%= t('home.hero.title_prefix') %><span class="accent"><%= t('home.hero.title_accent') %></span><%= t('home.hero.title_suffix') %>
        </h1>
        <p class="homeHero__lead heroHome__lead"><%= t('home.hero.lead') %></p>

        <div class="homeHero__actions heroHome__actions">
          <% if (me) { %>
            <a class="btn btn--primary btn--lg" href="/creator"><%= (lng==='en') ? 'Create a sales link' : '販売リンクを作る' %></a>
          <% } else { %>
            <a class="btn btn--primary btn--lg" href="/auth/google"><%= (lng==='en') ? 'Start selling (Google sign-in)' : 'Googleで始める' %></a>
          <% } %>
          <a class="btn btn--soft btn--lg" href="#howto"><%= (lng==='en') ? 'See how it works' : '使い方を見る' %></a>
        </div>
      </div>
    </div>
  </section>

  <section class="featureRow" aria-label="highlights">
    <article class="featureCard">
      <h3><%= (lng==='en') ? 'Instant link' : '即リンク発行' %></h3>
      <p class="muted"><%= (lng==='en') ? 'Upload → price → publish in 3 steps' : 'アップロード→価格→公開。3ステップで完了' %></p>
    </article>
    <article class="featureCard">
      <h3><%= (lng==='en') ? 'Secure payment' : '安全決済' %></h3>
      <p class="muted"><%= (lng==='en') ? 'Stripe card checkout supported' : 'Stripeのカード決済に対応' %></p>
    </article>
    <article class="featureCard">
      <h3><%= (lng==='en') ? 'Auto delivery' : '自動DL' %></h3>
      <p class="muted"><%= (lng==='en') ? 'Instant download after purchase' : '購入後すぐダウンロード' %></p>
    </article>
  </section>

  <section class="homeShowcase" aria-label="Sample sales page preview">
    <% const sampleHref = '#howto'; %>
    <h2 class="homeShowcase__title"><%= lng === 'en' ? 'Preview' : '完成イメージ' %></h2>
    <div class="homeShowcase__grid">
      <a class="sampleSaleCard" href="<%= sampleHref %>">
        <img class="sampleSaleCard__img" src="/public/og/instantsale_ogp.jpg" alt="Sample sale page preview" loading="lazy" />
        <div class="sampleSaleCard__body">
          <div class="sampleSaleCard__meta">
            <strong><%= lng === 'en' ? 'Neon Portrait Pack' : 'ネオンポートレート素材' %></strong>
            <span><%= lng === 'en' ? '$12' : '¥1,200' %></span>
          </div>
        </div>
      </a>
      <ul class="homeShowcase__points">
        <li><%= lng === 'en' ? 'Watermarked preview, full-res download after purchase' : 'プレビューは透かし入り、購入後に高解像度を自動ダウンロード' %></li>
        <li><%= lng === 'en' ? 'See fee & earnings instantly' : '価格設定と手数料がその場で分かる' %></li>
        <li><%= lng === 'en' ? 'Share the link on social' : '販売リンクをSNSで共有するだけ' %></li>
      </ul>
    </div>
  </section>

  <section id="howto" class="howtoSection">
    <div class="howtoHead">
      <h2 class="howtoTitle"><%= t('howto.title') %></h2>
      <p class="howtoLead"><%= (lng==='en') ? 'Upload → set price → publish. Your sales link is ready in minutes.' : 'アップロード → 価格設定 → 公開。数分で販売リンクが完成します。' %></p>
    </div>
    <div class="stepsWrap">
      <div class="steps">
        <article class="step"><div class="step__content"><div class="step__head"><div class="step__num">1</div><h3 class="step__title"><%= t('howto.step1.title') %></h3></div><p class="muted step__desc"><%= t('howto.step1.desc') %></p></div></article>
        <article class="step"><div class="step__content"><div class="step__head"><div class="step__num">2</div><h3 class="step__title"><%= t('howto.step2.title') %></h3></div><p class="muted step__desc"><%= t('howto.step2.desc') %></p></div></article>
        <article class="step"><div class="step__content"><div class="step__head"><div class="step__num">3</div><h3 class="step__title"><%= t('howto.step3.title') %></h3></div><p class="muted step__desc"><%= t('howto.step3.desc') %></p></div></article>
      </div>
    </div>
  </section>

  <section class="homeFaq" id="faq" aria-label="Frequently asked questions">
    <h2 class="homeFaq__title"><%= lng === 'en' ? 'FAQ' : 'よくある質問' %></h2>
    <div class="faqList">
      <details class="faqItem"><summary><%= lng === 'en' ? 'What happens to the SAMPLE watermark?' : '透かし（SAMPLE）はどうなる？' %></summary><p class="faqItem__body muted"><%= lng === 'en' ? 'The image on the sales page is a watermarked preview. After purchase, you can download the high-resolution file without the watermark.' : '販売ページの画像はプレビュー用の透かし入りです。購入後に高解像度（透かしなし）をダウンロードできます。' %></p></details>
      <details class="faqItem"><summary><%= lng === 'en' ? 'How do I receive files after purchase?' : '購入後はどうやって受け取る？' %></summary><p class="faqItem__body muted"><%= lng === 'en' ? 'After Stripe checkout, a download link is issued automatically (available for a limited time).' : 'Stripeで決済後、ダウンロードリンクが自動発行されます（一定時間有効）。' %></p></details>
      <details class="faqItem"><summary><%= lng === 'en' ? 'What do I need to start selling?' : '出品に必要な準備は？' %></summary><p class="faqItem__body muted"><%= lng === 'en' ? 'Just upload an image and set a price. To receive payouts, you need to complete Stripe payout setup.' : '画像をアップロードして価格を決めるだけです。売上受取にはStripeの受取設定が必要です。' %></p></details>
    </div>
  </section>

  <section class="homeCtaBand" aria-label="Final CTA">
    <% if (me) { %>
      <a class="btn btn--primary btn--lg" href="/creator"><%= (lng==='en') ? 'Create a sales link' : '販売リンクを作る' %></a>
    <% } else { %>
      <a class="btn btn--primary btn--lg" href="/auth/google"><%= (lng==='en') ? 'Start selling' : '出品を始める' %></a>
    <% } %>
    <p class="muted homeCtaBand__note"><%= (lng==='en') ? 'No card required to get started.' : '開始時にクレジットカード登録は不要です。' %></p>
  </section>

</main>

<%- include('partials/footer') %>

</body>
</html>
