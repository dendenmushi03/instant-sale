<!doctype html>
<html lang="<%= lng || 'ja' %>">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <title><%= (typeof og !== 'undefined' && og.title) ? og.title : t('home.title_full') %></title>
  <meta name="description" content="<%= (typeof og !== 'undefined' && og.desc) ? og.desc : t('home.hero.lead') %>" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content="<%= (og && og.title) || '' %>" />
  <meta property="og:description" content="<%= (og && og.desc) || '' %>" />
  <meta property="og:url" content="<%= (og && og.url) || (baseUrl || '') %>" />
  <meta property="og:image" content="<%= (og && og.image) || (baseUrl ? (baseUrl + '/public/og/instantsale_ogp.jpg') : '') %>" />

  <!-- X(Twitter) -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="<%= (og && og.title) || '' %>" />
  <meta name="twitter:description" content="<%= (og && og.desc) || '' %>" />
  <meta name="twitter:image" content="<%= (og && og.image) || (baseUrl ? (baseUrl + '/public/og/instantsale_ogp.jpg') : '') %>" />

  <link rel="stylesheet" href="/public/style.css?v=<%= assetVer %>" />
  <link rel="icon" href="/public/logo.png?v=<%= assetVer %>" />

  <!-- SEO basic -->
  <link rel="canonical" href="<%= canonical %>" />
  <meta name="robots" content="<%= robots %>" />

</head>

<body class="layout">

<%- include('partials/header') %>

<main class="container <%= me ? '' : 'homeMain--withFixedCta' %>">
  <section class="homeIntroCard" aria-label="About Instant Sale">
    <div class="homeIntroCard__inner homeIntroCard__grid">
      <div class="homeIntroCard__copy">
        <p class="homeIntroCard__kicker"><%= (lng === 'en') ? 'What this is' : 'このサイトについて' %></p>

        <p class="homeIntroCard__desc muted">
          <%= (lng === 'en')
            ? 'Create a shareable sales link for your images and sell via X in minutes.'
            : 'Xで作品を手軽に販売できる「販売リンク」を数分で発行できるサービスです。' %>
        </p>

        <div class="homeIntroCard__badges">
          <span class="pill"><%= (lng === 'en') ? 'Made for X sharing' : 'Xシェア前提' %></span>
          <span class="pill"><%= (lng === 'en') ? 'Stripe checkout' : 'Stripe決済' %></span>
          <span class="pill"><%= (lng === 'en') ? 'Auto delivery' : '自動納品' %></span>
        </div>
      </div>

      <div class="homeIntroCard__media" aria-hidden="true">
        <img
          class="homeIntroPreviewImg"
          src="/public/og/home_preview_sale_page.jpg"
          alt="<%= (lng==='en') ? 'Sales page preview' : '販売ページのプレビュー' %>"
          loading="lazy"
        >
      </div>

      <div class="homeIntroCard__cta <%= me ? '' : 'homeIntroCard__cta--fixedMobile' %>">
        <% if (me) { %>
          <a class="btn btn--primary btn--lg" href="/creator"><%= (lng==='en') ? 'Create a sales link' : '販売リンクを作る' %></a>
        <% } else { %>
          <button
            class="btn btn--primary btn--lg"
            type="button"
            data-home-login-trigger
            aria-haspopup="dialog"
            aria-controls="homeLoginModal"
          ><%= (lng==='en') ? 'Create a sales link' : '販売リンクを作成する' %></button>
        <% } %>
      </div>
    </div>
  </section>

  <section id="howto" class="howtoSection">
    <div class="howtoHead">
      <p class="howtoTitle"><%= t('howto.title') %></p>

      <p class="howtoLead"><%= (lng==='en') ? 'Upload → set price → publish. Your sales link is ready in minutes.' : 'アップロード → 価格設定 → 公開。数分で販売リンクが完成します。' %></p>
    </div>

    <div class="stepsWrap">
      <div class="steps">
        <article class="step"><div class="step__content"><div class="step__head"><div class="step__num">1</div><h3 class="step__title"><%= t('howto.step1.title') %></h3></div><p class="muted step__desc"><%= t('howto.step1.desc') %></p></div></article>
        <article class="step"><div class="step__content"><div class="step__head"><div class="step__num">2</div><h3 class="step__title"><%= t('howto.step2.title') %></h3></div><p class="muted step__desc"><%= t('howto.step2.desc') %></p></div></article>
        <article class="step"><div class="step__content"><div class="step__head"><div class="step__num">3</div><h3 class="step__title"><%= t('howto.step3.title') %></h3></div><p class="muted step__desc"><%= t('howto.step3.desc') %></p></div></article>
      </div>
    </div>
  </section>

  <section class="homeHighlights" aria-label="Highlights">
    <div class="homeHighlights__card">
      <div class="homeHighlights__head">
        <p class="homeHighlights__title"><%= (lng==='en') ? 'Features' : '特徴' %></p>

      </div>

      <div class="highlightList">
        <article class="highlightItem">
          <div class="highlightIcon" aria-hidden="true">💳</div>
          <div class="highlightText">
            <div class="highlightTitle"><%= (lng==='en') ? 'Secure payment' : '安全な決済' %></div>
            <div class="highlightDesc"><%= (lng==='en') ? 'Stripe card checkout' : 'Stripeのカード決済' %></div>
          </div>
        </article>
        <article class="highlightItem">
          <div class="highlightIcon" aria-hidden="true">⚡</div>
          <div class="highlightText">
            <div class="highlightTitle"><%= (lng==='en') ? 'Auto delivery' : '自動ダウンロード' %></div>
            <div class="highlightDesc"><%= (lng==='en') ? 'Instant download after purchase' : '購入後すぐに受け取れます' %></div>
          </div>
        </article>
        <article class="highlightItem">
          <div class="highlightIcon" aria-hidden="true">🖼️</div>
          <div class="highlightText">
            <div class="highlightTitle"><%= (lng==='en') ? 'Preview protection' : 'プレビュー保護' %></div>
            <div class="highlightDesc"><%= (lng==='en') ? 'Watermarked preview' : '透かし付きで公開' %></div>
          </div>
        </article>
      </div>

      <div class="highlightTags">
        <span class="highlightTag"><%= (lng==='en') ? 'Done in 3 steps' : '3ステップで完了' %></span>
        <span class="highlightTag"><%= (lng==='en') ? 'Secure with Stripe' : 'Stripeで安全決済' %></span>
        <span class="highlightTag"><%= (lng==='en') ? 'Auto link' : 'リンク自動発行' %></span>
      </div>

      <p class="highlightNote muted"><%= (lng==='en') ? 'No card needed • Link ready in ~30 seconds' : 'クレカ不要・30秒でリンク発行' %></p>
    </div>

  </section>

  <section class="homeFaq" id="faq" aria-label="Frequently asked questions">
    <p class="homeFaq__title"><%= lng === 'en' ? 'FAQ' : 'よくある質問' %></p>
    <div class="faqList">
      <details class="faqItem"><summary><%= lng === 'en' ? 'What happens to the SAMPLE watermark?' : '透かし（SAMPLE）はどうなる？' %></summary><p class="faqItem__body muted"><%= lng === 'en' ? 'The image on the sales page is a watermarked preview. After purchase, you can download the high-resolution file without the watermark.' : '販売ページの画像はプレビュー用の透かし入りです。購入後に高解像度（透かしなし）をダウンロードできます。' %></p></details>
      <details class="faqItem"><summary><%= lng === 'en' ? 'How do I receive files after purchase?' : '購入後はどうやって受け取る？' %></summary><p class="faqItem__body muted"><%= lng === 'en' ? 'After Stripe checkout, a download link is issued automatically (available for a limited time).' : 'Stripeで決済後、ダウンロードリンクが自動発行されます（一定時間有効）。' %></p></details>
      <details class="faqItem"><summary><%= lng === 'en' ? 'What do I need to start selling?' : '出品に必要な準備は？' %></summary><p class="faqItem__body muted"><%= lng === 'en' ? 'Just upload an image and set a price. To receive payouts, you need to complete Stripe payout setup.' : '画像をアップロードして価格を決めるだけです。売上受取にはStripeの受取設定が必要です。' %></p></details>
    </div>
  </section>
</main>


<% if (!me) { %>
  <div class="homeLoginModal" id="homeLoginModal" role="dialog" aria-modal="true" aria-labelledby="homeLoginTitle" hidden>
    <div class="homeLoginModal__backdrop" data-home-login-close></div>

    <div class="homeLoginModal__decor" aria-hidden="true">
      <span class="homeLoginModal__blob homeLoginModal__blob--one"></span>
      <span class="homeLoginModal__blob homeLoginModal__blob--two"></span>
      <span class="homeLoginModal__blob homeLoginModal__blob--three"></span>
    </div>

    <div class="homeLoginModal__panel" role="document">
      <div class="homeLoginModal__tabWrap" aria-hidden="true">
        <span class="homeLoginModal__tab homeLoginModal__tab--active"><%= (lng==='en') ? 'Login' : 'ログイン' %></span>
        <span class="homeLoginModal__tab homeLoginModal__tab--placeholder"></span>
      </div>

      <div class="homeLoginModal__brand" aria-hidden="true">
        <span class="homeLoginModal__brandBadge">INSTANT<br>SALE</span>
      </div>

      <p id="homeLoginTitle" class="homeLoginModal__lead"><%= (lng==='en') ? 'To create a sales link, please sign in with Google.' : '販売リンクの作成には、Googleアカウントでのログインが必要です。' %></p>

      <a class="btn btn--lg homeLoginModal__googleBtn" href="/auth/google">
        <span class="homeLoginModal__googleMark" aria-hidden="true">G</span>
        <span><%= (lng==='en') ? 'Continue with Google' : 'Googleでログイン' %></span>
      </a>

      <button class="homeLoginModal__dismiss" type="button" data-home-login-close><%= (lng==='en') ? 'Close' : '閉じる' %></button>
    </div>
  </div>

  <script nonce="<%= cspNonce %>">
    (() => {
      const modal = document.getElementById('homeLoginModal');
      const trigger = document.querySelector('[data-home-login-trigger]');
      if (!modal || !trigger) return;

      const closeTargets = modal.querySelectorAll('[data-home-login-close]');
      const panel = modal.querySelector('.homeLoginModal__panel');
      let isOpen = false;

      const openModal = () => {
        if (isOpen) return;
        modal.hidden = false;
        document.body.classList.add('modal-open');
        isOpen = true;
      };

      const closeModal = () => {
        if (!isOpen) return;
        modal.hidden = true;
        document.body.classList.remove('modal-open');
        isOpen = false;
        trigger.focus();
      };

      trigger.addEventListener('click', (event) => {
        event.preventDefault();
        openModal();
      });

      closeTargets.forEach((node) => node.addEventListener('click', closeModal));

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeModal();
      });

      modal.addEventListener('click', (event) => {
        if (event.target === modal || event.target.classList.contains('homeLoginModal__backdrop')) {
          closeModal();
        }
      });

      panel?.addEventListener('click', (event) => event.stopPropagation());
    })();
  </script>
<% } %>

<%- include('partials/footer') %>

</body>
</html>
