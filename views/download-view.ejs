<!doctype html>
<html lang="<%= lng || 'ja' %>">

<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title><%= t('download.title', { title: item.title }) %></title>
  <link rel="stylesheet" href="/public/style.css?v=<%= assetVer %>">
</head>

<body class="layout downloadPage">

<%- include('partials/header') %>

<% const locale = (lng === 'en' ? 'en-US' : 'ja-JP'); %>

<main class="container">
  <div class="dlWrap">

    <section class="card dlInfo" aria-label="download notice">
      <p class="muted dlHero__meta"><%= lng === 'en' ? 'Expires in: ' : '有効期限：' %><%= ttlMin %><%= lng === 'en' ? ' min' : '分' %>（<%= lng === 'en' ? 'until ' : '' %><%= expiresAt.toLocaleString(locale) %><%= lng === 'en' ? '' : 'まで' %>）</p>
      <p class="muted"><%= t('download.open_notice_line1') %></p>
      <p class="muted"><%= t('download.open_notice_line2') %></p>
      <p class="dlHero__actions">
        <a class="btn btn--primary" href="<%= openUrl %>"><%= t('download.open_btn') %></a>
        <a class="btn btn--ghost" href="<%= saveUrl %>"><%= t('download.save_btn') %></a>
      </p>
      <p class="muted"><%= t('download.expire_notice_10min') %></p>
    </section>


</div>
</main>

<%- include('partials/footer') %>

</body>
</html>
