<!doctype html>
<html lang="<%= lng || 'ja' %>">

<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title><%= t('download.title', { title: item.title }) %></title>
  <link rel="stylesheet" href="/public/style.css?v=<%= assetVer %>">
</head>

<body class="layout downloadPage">

<%- include('partials/header') %>

<% const locale = (lng === 'en' ? 'en-US' : 'ja-JP'); %>

<main class="container">
  <div class="dlWrap">
    <section class="card success dlHero" aria-labelledby="dlTitle">
      <h1 id="dlTitle" class="dlHero__title"><%= lng === 'en' ? 'Thanks for your purchase 🎉' : 'ご購入ありがとうございます 🎉' %></h1>
      <p class="dlHero__desc"><%= lng === 'en' ? 'You can download the high-resolution file using the button below.' : '下のボタンから高解像度データをダウンロードできます。' %></p>
      <p class="muted dlHero__meta"><%= lng === 'en' ? 'Valid for' : '有効期限：' %><%= ttlMin %><%= lng === 'en' ? ' min' : '分' %>（<%= expiresAt.toLocaleString(locale) %> <%= lng === 'en' ? 'until' : 'まで' %>）</p>
      <p class="dlHero__actions">
        <a class="btn btn--primary btn--lg" href="<%= imageUrl %>"><%= lng === 'en' ? 'Download' : 'ダウンロード' %></a>
      </p>
    </section>

    <section class="card dlInfo" aria-label="download notice">
      <p class="muted"><%= lng === 'en' ? 'This link becomes invalid after the expiration time.' : '※リンクは有効期限を過ぎると無効になります。' %></p>
      <p class="muted"><%= lng === 'en' ? 'On iPhone, you can save the image by long-pressing it.' : '※iPhoneは画像を長押しで保存できます。' %></p>
    </section>

    <section class="card dlPreview" aria-label="image preview">
      <img class="dlImage" src="<%= imageUrl %>" alt="<%= t('download.img_alt', { title: item.title }) %>">
    </section>
  </div>
</main>

<%- include('partials/footer') %>

</body>
</html>
