<!doctype html>
<html lang="<%= lng || 'ja' %>">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= (lng === 'en') ? 'Notice' : 'お知らせ' %> | Instant Sale</title>
  <link rel="stylesheet" href="/public/style.css?v=<%= assetVer %>" />
  <link rel="icon" href="/public/logo.png?v=<%= assetVer %>" />
</head>

<body class="layout">

<%- include('partials/header') %>

<main class="container errorPage">
<%
  const tone = (variant === 'success') ? 'success' : 'error';
  const eyebrow = (typeof pageLabel === 'string' && pageLabel)
    ? pageLabel
    : ((tone === 'success') ? ((lng === 'en') ? 'RESULT' : '接続結果') : 'ERROR');
  const heading = (typeof title === 'string' && title)
    ? title
    : ((tone === 'success') ? ((lng === 'en') ? 'Completed' : '完了しました') : ((lng === 'en') ? 'Error' : 'エラー'));
  const primaryHref = (primaryAction && primaryAction.href) ? primaryAction.href : '/';
  const primaryLabel = (primaryAction && primaryAction.label)
    ? primaryAction.label
    : ((lng === 'en') ? 'Back to top' : 'トップに戻る');
%>

<section class="card errorCard <%= (tone === 'success') ? 'errorCard--success' : '' %>">
  <p class="errorCard__eyebrow"><%= eyebrow %></p>
  <h1 class="errorCard__title"><%= heading %></h1>
  <p class="errorCard__desc"><%- message %></p>

  <% if (typeof subMessage === 'string' && subMessage) { %>
    <p class="errorCard__sub muted"><%= subMessage %></p>
  <% } %>

  <div class="errorCard__actions">
    <a class="btn btn--primary" href="<%= primaryHref %>"><%= primaryLabel %></a>
    <% if (secondaryAction && secondaryAction.href && secondaryAction.label) { %>
      <a class="btn btn--soft" href="<%= secondaryAction.href %>"><%= secondaryAction.label %></a>
    <% } %>
  </div>
</section>

</main>

<%- include('partials/footer') %>
  
</body>
</html>
