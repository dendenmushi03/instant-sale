<!doctype html>
<html lang="<%= lng || 'ja' %>">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= (lng === 'en') ? 'Notice' : 'お知らせ' %> | Instant Sale</title>
  <link rel="stylesheet" href="/public/style.css?v=<%= assetVer %>" />
  <link rel="icon" href="/public/logo.png?v=<%= assetVer %>" />
</head>

<body class="layout">

<%- include('partials/header') %>

<main class="container errorPage">
<%
  const safeVariant = (typeof variant !== 'undefined' && variant) ? variant : 'error';
  const safePageLabel = (typeof pageLabel === 'string') ? pageLabel : '';
  const safeTitle = (typeof title === 'string') ? title : '';
  const safeMessage = (typeof message === 'string') ? message : '';
  const safeSubMessage = (typeof subMessage === 'string') ? subMessage : '';
  const safePrimaryAction =
    (typeof primaryAction !== 'undefined' && primaryAction && typeof primaryAction === 'object')
      ? primaryAction
      : null;
  const safeSecondaryAction =
    (typeof secondaryAction !== 'undefined' && secondaryAction && typeof secondaryAction === 'object')
      ? secondaryAction
      : null;

  const tone = (safeVariant === 'success') ? 'success' : 'error';
  const rawEyebrow = safePageLabel
    ? safePageLabel
    : ((tone === 'success') ? ((lng === 'en') ? 'RESULT' : '接続結果') : 'ERROR');
  const rawHeading = safeTitle
    ? safeTitle
    : ((tone === 'success') ? ((lng === 'en') ? 'Completed' : '完了しました') : ((lng === 'en') ? 'Error' : 'エラー'));
  const rawMessage = safeMessage;

  const eyebrow = (lng !== 'en' && rawEyebrow === '接続結果') ? 'エラー' : rawEyebrow;
  const heading = (lng !== 'en' && rawHeading === '接続設定を受け付けました。') ? '' : rawHeading;
  const desc = (lng !== 'en' && rawMessage === '受取設定の状態を確認し、必要な処理を反映しました。')
    ? '以下より再度アクセスして下さい。'
    : rawMessage;

  const primaryHref = (safePrimaryAction && safePrimaryAction.href) ? safePrimaryAction.href : '/';
  const primaryLabel = (safePrimaryAction && safePrimaryAction.label)
    ? safePrimaryAction.label
    : ((lng === 'en') ? 'Back to top' : 'トップに戻る');
%>

<section class="card errorCard <%= (tone === 'success') ? 'errorCard--success' : '' %>">
  <p class="errorCard__eyebrow"><%= eyebrow %></p>
  <% if (heading) { %><h1 class="errorCard__title"><%= heading %></h1><% } %>
  <p class="errorCard__desc"><%- desc %></p>

  <% if (safeSubMessage) { %>
    <p class="errorCard__sub muted"><%= safeSubMessage %></p>
  <% } %>

  <div class="errorCard__actions">
    <a class="btn btn--primary" href="<%= primaryHref %>"><%= primaryLabel %></a>
    <% if (safeSecondaryAction && safeSecondaryAction.href && safeSecondaryAction.label) { %>
      <a class="btn btn--soft" href="<%= safeSecondaryAction.href %>"><%= safeSecondaryAction.label %></a>
    <% } %>
  </div>
</section>

</main>

<%- include('partials/footer') %>
  
</body>
</html>
