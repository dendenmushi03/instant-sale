# サイトの絶対URL（OGPで必須）例: https://your-app.onrender.com
BASE_URL=http://localhost:3000

# MongoDB Atlas など
MONGODB_URI=mongodb://127.0.0.1:27017/instant_sale

# Stripe 秘密鍵（テストキーでOK: sk_test_...）
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxx

# 既定通貨（日本なら jpy）
CURRENCY=jpy

# シンプルな作成用パスワード（アップロードUIのガード）
CREATOR_SECRET=changeme

# ダウンロードURLの有効期間（分）
DOWNLOAD_TOKEN_TTL_MIN=120

# 画像モデレーション設定（OPENAI利用時のみ）
IMAGE_REVIEW_MODE=stub
# OPENAI_API_KEY=sk-...
OPENAI_IMAGE_REVIEW_TIMEOUT_MS=7000
OPENAI_IMAGE_REVIEW_SCORE_THRESHOLD=0.2
OPENAI_IMAGE_REVIEW_MAX_SIDE=1536
OPENAI_IMAGE_REVIEW_JPEG_QUALITY=75
